# Auto AI App Builder — server configuration
# Copy to .env and edit as needed. All values are optional.

# Where generated projects and build artifacts are stored on disk.
DATA_DIR=./_data

# Code generation provider: auto | templated | anthropic
# "auto" picks anthropic when ANTHROPIC_API_KEY is set, else templated.
CODEGEN_PROVIDER=auto

# Build provider: stub | docker | codemagic
# "stub" produces a fake APK (renamed zip) — fine for UI/dev work.
# "docker" runs cirrusci/flutter:stable locally; needs Docker available.
BUILDER_PROVIDER=stub

# Anthropic Claude — only used when CODEGEN_PROVIDER resolves to "anthropic".
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Docker builder config (only used when BUILDER_PROVIDER=docker).
# DOCKER_FLUTTER_IMAGE=cirrusci/flutter:stable
# DOCKER_BUILD_TIMEOUT_SECONDS=1800

# CORS — tighten in production.
# CORS_ALLOW_ORIGINS=["http://localhost:3000"]
